      "content": ".skin-black {\n  --adminlte-skin-navbar-bg: #ffffff;\n  --adminlte-skin-navbar-color: #333333;\n  --adminlte-skin-navbar-border: 1px solid #d2d6de;\n  --adminlte-skin-logo-bg: #ffffff;\n  --adminlte-skin-logo-color: #333333;\n  --adminlte-skin-logo-hover-bg: #fcfcfc;\n  --adminlte-skin-sidebar-bg: #222d32;\n  --adminlte-skin-sidebar-color: #b8c7ce;\n  --adminlte-skin-sidebar-hover-bg: #1e282c;\n  --adminlte-skin-sidebar-hover-color: #ffffff;\n  --adminlte-skin-sidebar-active-border: #444444;\n  --adminlte-skin-sidebar-active-bg: #1e282c;\n  --adminlte-skin-sidebar-active-color: #ffffff;\n  --adminlte-skin-sidebar-submenu-bg: #2c3b41;\n  --adminlte-skin-sidebar-submenu-color: #8aa4af;\n  --adminlte-skin-sidebar-submenu-hover-color: #ffffff;\n  --adminlte-skin-sidebar-header-bg: #1a2226;\n  --adminlte-skin-sidebar-header-color: #4b646f;\n  --adminlte-skin-user-panel-color: #ffffff;\n}\n",
